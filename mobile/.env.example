# Production backend (Railway) — used by all devices on any network
EXPO_PUBLIC_API_URL=https://strangerconnect-production.up.railway.app/api/v1
EXPO_PUBLIC_SOCKET_URL=https://strangerconnect-production.up.railway.app

# Local development only — both phones must be on the same Wi-Fi as your laptop
# EXPO_PUBLIC_USE_LOCAL=true
# EXPO_PUBLIC_DEV_SERVER_HOST=192.168.1.100

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
