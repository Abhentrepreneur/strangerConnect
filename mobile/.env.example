# REQUIRED for physical phone: your laptop's LAN IP (same Wi-Fi as phone)
# Mac: ipconfig getifaddr en0
EXPO_PUBLIC_DEV_SERVER_HOST=192.168.1.100

# Android emulator only
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api/v1
EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:3000

# iOS simulator only
EXPO_PUBLIC_API_URL_IOS=http://localhost:3000/api/v1
EXPO_PUBLIC_SOCKET_URL_IOS=http://localhost:3000

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
